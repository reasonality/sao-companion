{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "equipment_store.v2",
  "type": "object",
  "required": ["byId", "nameToId"],
  "properties": {
    "byId": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["equipment_id", "name", "slot", "weapon_type", "rarity", "item_level", "stats", "affixes", "description", "source"],
        "properties": {
          "equipment_id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "slot": { "type": "string", "enum": ["weapon", "off_hand", "head", "chest", "hands", "legs", "accessory"] },
          "weapon_type": { "type": "string", "minLength": 1 },
          "rarity": { "type": "string", "enum": ["common", "uncommon", "rare", "epic", "legendary"] },
          "item_level": { "type": "integer", "minimum": 1 },
          "stats": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "atk": { "type": "number", "minimum": 0 },
              "str": { "type": "number", "minimum": 0 },
              "agi": { "type": "number", "minimum": 0 },
              "int": { "type": "number", "minimum": 0 },
              "vit": { "type": "number", "minimum": 0 },
              "maxHp": { "type": "number", "minimum": 0 },
              "maxMp": { "type": "number", "minimum": 0 },
              "hit": { "type": "number", "minimum": 0 },
              "crit": { "type": "number", "minimum": 0 }
            }
          },
          "affixes": { "type": "array", "items": { "type": "string" } },
          "description": { "type": "string", "minLength": 1 },
          "source": { "type": "string", "minLength": 1 }
        }
      }
    },
    "nameToId": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    }
  }
}
